{
	"name": "hwis",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.6",
	"scripts": {
		"dev": "vite dev",
		"convex:local:recover": "bash scripts/convex-local-recover.sh",
		"convex:local:env-sync": "bash scripts/convex-local-env-sync.sh",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:unit:convex": "vitest run src/convex",
		"test:component": "vitest run --config vitest.component.config.ts",
		"test:component:watch": "vitest --config vitest.component.config.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:cleanup": "playwright test --project=cleanup",
		"test:e2e:setup": "bash scripts/setup-test-users.sh",
		"test:e2e:auth": "bunx playwright test --project=authenticated",
		"test:e2e:full": "bun run test:e2e:setup && bun run test:e2e && bun run test:e2e:cleanup",
		"test:all": "bun run test:unit -- --run && bun run test:e2e:setup && bunx playwright test && bun run test:e2e:auth && bun run test:e2e:cleanup",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"precommit": "bun run test:e2e",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@edge-runtime/vm": "^5.0.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20.19.41",
		"@vitest/browser": "^4.1.7",
		"@vitest/browser-playwright": "^4.1.7",
		"bits-ui": "^2.18.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex-helpers": "^0.1.118",
		"convex-test": "^0.0.41",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^7.3.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.7",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.10.13",
		"@mmailaender/convex-better-auth-svelte": "^0.5.3",
		"@types/d3": "^7.4.3",
		"better-auth": "1.4.9",
		"convex": "^1.42.0",
		"convex-svelte": "^0.0.12",
		"d3": "^7.9.0",
		"d3-scale-chromatic": "^3.1.0",
		"googleapis": "^171.4.0"
	}
}
